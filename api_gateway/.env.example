APP_NAME=Champs Closet API Gateway
LOG_LEVEL=INFO

# Frontend should call the gateway only
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Public site base URL used in sitemap/robots
SITE_BASE_URL=http://localhost:3000

# Internal service URLs
PRODUCT_SERVICE_URL=http://localhost:8000
ORDER_SERVICE_URL=http://localhost:8003
INGESTION_SERVICE_URL=http://localhost:8002
AI_SERVICE_URL=http://localhost:8001
NOTIFICATION_SERVICE_URL=http://localhost:8004

HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE_CONNECTIONS=20
MAX_REQUEST_BODY_BYTES=2097152
REQUEST_ID_HEADER=X-Request-ID

# Cache
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true
CACHE_TTL_SECONDS=60

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Firebase admin auth
FIREBASE_AUTH_DISABLED=false
FIREBASE_CREDENTIALS_PATH=./firebase.json
FIREBASE_REQUIRE_ADMIN_CLAIM=true
FIREBASE_ADMIN_EMAILS=

# Optional service-to-service tokens
PRODUCT_SERVICE_INTERNAL_TOKEN=
ORDER_SERVICE_INTERNAL_TOKEN=
